<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.itheima.mapper.MemberMapper">

    <select id="list" resultType="com.itheima.pojo.Member">
        SELECT * FROM member
        <where>
            <if test="name != null and name != ''">
                AND name LIKE CONCAT('%', #{name}, '%')
            </if>
            <if test="phone != null and phone != ''">
                AND phone LIKE CONCAT('%', #{phone}, '%')
            </if>
            <if test="level != null">
                AND level = #{level}
            </if>
        </where>
        ORDER BY growth DESC, registered_at DESC
    </select>

    <update id="updateById">
        UPDATE member
        <set>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="phone != null and phone != ''">phone = #{phone},</if>
            <if test="level != null">level = #{level},</if>
            <if test="points != null">points = #{points},</if>
            <if test="totalPoints != null">total_points = #{totalPoints},</if>
            <if test="growth != null">growth = #{growth},</if>
            <if test="totalSpent != null">total_spent = #{totalSpent},</if>
            <if test="orderCount != null">order_count = #{orderCount},</if>
            <if test="birthday != null">birthday = #{birthday},</if>
            updated_at = NOW()
        </set>
        WHERE id = #{id}
    </update>

</mapper>
